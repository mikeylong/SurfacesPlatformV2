{
  "$id": "https://surfaces.dev/schemas/p2/design-source-manifest.v0.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaId",
    "version",
    "designSystemId",
    "designSystemName",
    "sourceFamily",
    "packageName",
    "packageVersion",
    "packageTarball",
    "packageIntegrity",
    "snapshotRoot",
    "sourceRefGrammar",
    "initialComponents",
    "sourceFiles",
    "requiredMappings",
    "policyRefs",
    "generatedAt",
    "environment"
  ],
  "properties": {
    "schemaId": { "const": "design-source-manifest.v0" },
    "version": { "type": "string" },
    "designSystemId": { "const": "adobe-spectrum" },
    "designSystemName": { "const": "Adobe Spectrum Design Data" },
    "sourceFamily": { "const": "design-system-source-bundle.v0" },
    "packageName": { "const": "@adobe/spectrum-design-data" },
    "packageVersion": { "const": "0.7.0" },
    "packageTarball": { "const": "https://registry.npmjs.org/@adobe/spectrum-design-data/-/spectrum-design-data-0.7.0.tgz" },
    "packageIntegrity": {
      "const": "sha512-mSdmQn6fNEzKVo6W5xS4gO1EXCpC4ojiEm3GqTlSjhh26lC9siMgQSWi33ODvWe8ssfrxXX0unzVnL5VBt4+CA=="
    },
    "snapshotRoot": {
      "const": "sources/p2/design-system-source/npm/@adobe/spectrum-design-data/0.7.0/package"
    },
    "sourceRefGrammar": {
      "const": "spectrum-design-data://npm/@adobe/spectrum-design-data@0.7.0/package/<posix-package-path>#<rfc6901-json-pointer>"
    },
    "initialComponents": {
      "type": "array",
      "prefixItems": [
        { "const": "button" },
        { "const": "in-line-alert" }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "sourceFiles": {
      "type": "array",
      "minItems": 32,
      "items": { "$ref": "#/$defs/sourceFile" }
    },
    "requiredMappings": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/requiredMapping" }
    },
    "policyRefs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sourceRef" }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object",
      "required": ["host"],
      "properties": {
        "host": { "type": "null" }
      },
      "unevaluatedProperties": false
    }
  },
  "$defs": {
    "sourceRef": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^spectrum-design-data://npm/@adobe/spectrum-design-data@0\\.7\\.0/package/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[A-Za-z0-9._@-]+(?:/[A-Za-z0-9._@-]+)*#/(?:[A-Za-z0-9._~-]+(?:/[A-Za-z0-9._~-]+)*)?$"
        },
        {
          "type": "string",
          "pattern": "^source://p2/docs/usage-policy\\.json#/(?:[A-Za-z0-9._~-]+(?:/[A-Za-z0-9._~-]+)*)?$"
        }
      ]
    },
    "mappingRef": {
      "type": "string",
      "pattern": "^mapping://p2/spectrum/(component-map|token-map|policy-map)\\.json#/(?:[A-Za-z0-9._~-]+(?:/[A-Za-z0-9._~-]+)*)?$"
    },
    "sourceFile": {
      "type": "object",
      "required": [
        "path",
        "packagePath",
        "sourceType",
        "sourceSystem",
        "hashAlgorithm",
        "sha256",
        "sourceRefRoot"
      ],
      "oneOf": [
        {
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^npm/@adobe/spectrum-design-data/0\\.7\\.0/package/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[A-Za-z0-9._@-]+(?:/[A-Za-z0-9._@-]+)*$"
            },
            "packagePath": {
              "type": "string",
              "pattern": "^(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[A-Za-z0-9._@-]+(?:/[A-Za-z0-9._@-]+)*$"
            },
            "sourceSystem": { "const": "npm:@adobe/spectrum-design-data" },
            "sourceRefRoot": {
              "type": "string",
              "pattern": "^spectrum-design-data://npm/@adobe/spectrum-design-data@0\\.7\\.0/package/(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)[A-Za-z0-9._@-]+(?:/[A-Za-z0-9._@-]+)*#/$"
            }
          }
        },
        {
          "properties": {
            "path": {
              "type": "string",
              "const": "docs/usage-policy.json"
            },
            "packagePath": { "type": "null" },
            "sourceSystem": { "const": "local:p2-docs" },
            "sourceRefRoot": {
              "type": "string",
              "const": "source://p2/docs/usage-policy.json#/"
            }
          }
        }
      ],
      "properties": {
        "sourceType": {
          "enum": ["package", "component", "token", "registry", "field", "mode", "guideline", "policy"]
        },
        "hashAlgorithm": { "const": "sha256" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "unevaluatedProperties": false
    },
    "requiredMapping": {
      "type": "object",
      "required": ["path", "mappingRefRoot", "hashAlgorithm", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^mappings/(component-map|token-map|policy-map)\\.json$"
        },
        "mappingRefRoot": { "$ref": "#/$defs/mappingRef" },
        "hashAlgorithm": { "const": "sha256" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "unevaluatedProperties": false
    },
    "requiredSourcePackageJson": {
      "properties": {
        "sourceFiles": {
          "contains": { "$ref": "#/$defs/sourceFilePackageJson" },
          "minContains": 1,
          "maxContains": 1
