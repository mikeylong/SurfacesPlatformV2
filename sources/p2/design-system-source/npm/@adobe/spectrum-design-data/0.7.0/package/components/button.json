{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/button.json",
  "specVersion": "1.0.0-draft",
  "name": "button",
  "displayName": "Button",
  "description": "Buttons allow users to perform an action or to navigate to another page.",
  "meta": {
    "category": "actions",
    "documentationUrl": "https://spectrum.adobe.com/page/button/"
  },
  "documentBlocks": [
    {
      "type": "purpose",
      "content": "Buttons enable actions or navigation between views. They come in multiple styles to support different levels of emphasis, and are commonly used to guide progression through a flow."
    },
    {
      "type": "guideline",
      "content": "Keyboard focus.\n\nA button can be navigated using a keyboard. The keyboard focus state takes the button's visual hover state and adds a blue ring to the button in focus."
    },
    {
      "type": "guideline",
      "content": "Tooltip when the label is hidden.\n\nWhen the button label is hidden, a tooltip is shown on hover that displays the label text and, if appropriate, a keyboard shortcut."
    },
    {
      "type": "guideline",
      "content": "Flexible width.\n\nThe width of a button automatically adjusts to fit the label text. The padding on each side of the button is equal to half its height."
    },
    {
      "type": "guideline",
      "content": "Minimum width.\n\nButtons have a minimum width of 2.25× the height of the button. This ensures that small buttons retain an identifiable shape."
    },
    {
      "type": "guideline",
      "content": "Text overflow.\n\nWhen the button text is too long for the horizontal space available, it wraps to form another line."
    },
    {
      "type": "guideline",
      "content": "Cursor style.\n\nButtons use the default arrow cursor for all states, including hover and down. The only exception occurs on the web; if the button is using the href property it will display the pointer cursor instead."
    },
    {
      "type": "guideline",
      "content": "Delay before pending state.\n\nSome progress can be very quick. In order to avoid showing a progress circle for a fraction of a second, which results in an unpleasant flickering, there is a delay of 1 second before the pending state appears. During this delay, the button continues to visually respond to interactive events (e.g., hover), but additional clicks do not result in repeated submissions."
    },
    {
      "type": "guideline",
      "content": "Use icons only when necessary.\n\nIcons can be used in buttons when additional clarity is required and the icon is highly relevant to the action. Icons should not be used for decoration."
    },
    {
      "type": "do-dont",
      "content": "Don't override color",
      "dont": "Do not use custom colors for buttons. The colors of different button variations have been designed to be consistent and accessible."
    },
    {
      "type": "guideline",
      "content": "When to use static black and static white.\n\nTo ensure maximum contrast with the background, use static black for light backgrounds and images, and use static white for dark backgrounds and images. Avoid placing static components on top of busy images with a lot of variance in contrast."
    },
    {
      "type": "do-dont",
      "content": "Don't use the pending state for long progress",
      "dont": "The pending state should be reserved for indeterminate actions that are expected to take 5 seconds or less. For determinate or longer actions, use a [progress bar](https://spectrum.adobe.com/page/progress-bar/) or [progress circle](https://spectrum.adobe.com/page/progress-circle/) outside of the button."
    },
    {
      "type": "guideline",
      "content": "Use a button group to show additional actions.\n\nInstead of a single split button (now a deprecated component), use a [button group](https://spectrum.adobe.com/page/button-group/) to show any additional actions related to the most critical action."
    },
    {
      "type": "guideline",
      "content": "Display a popover when featuring subsequent options.\n\nIn some instances, it's possible to have a call to action button display a popover (or tray) to feature subsequent options. These options should extend and parallel the action of the button. Do not include arbitrary or unrelated options."
    }
  ],
  "options": {
    "variant": {
      "type": "string",
      "default": "accent",
      "description": "Visual emphasis level.",
      "values": [
        { "value": "accent" },
        { "value": "negative" },
        { "value": "primary" },
        { "value": "secondary" }
      ]
    },
    "style": {
      "type": "string",
      "default": "fill",
      "values": [{ "value": "fill" }, { "value": "outline" }]
    },
    "size": {
      "type": "string",
      "default": "m",
      "values": [
        { "value": "s" },
        { "value": "m" },
        { "value": "l" },
        { "value": "xl" }
      ]
    },
    "isDisabled": { "type": "boolean", "default": false },
    "isPending": { "type": "boolean", "default": false },
    "isLabelHidden": { "type": "boolean", "default": false },
    "icon": {
      "$ref": "https://opensource.adobe.com/spectrum-design-data/schemas/types/workflow-icon.json",
      "description": "Icon placed at the start of the button. Required when isLabelHidden is true."
    },
    "staticColor": {
      "type": "string",
      "description": "Static color for use on colored backgrounds.",
      "values": [{ "value": "white" }, { "value": "black" }]
    }
  },
  "slots": [
    {
      "name": "default",
      "description": "Text label of the button.",
      "required": false
    },
    { "name": "icon", "description": "Icon placed at the start of the button." }
  ],
  "anatomy": [
    { "name": "icon", "description": "Leading icon." },
    { "name": "label", "description": "Button text.", "required": true }
  ],
  "states": [
    { "name": "hover", "trigger": "interaction", "precedence": 50 },
    {
      "name": "focus",
      "trigger": "interaction",
      "precedence": 60,
      "layered": true
    },
    { "name": "disabled", "trigger": "prop", "precedence": 100 }
  ],
